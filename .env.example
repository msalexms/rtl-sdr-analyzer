# RTL-SDR Analyzer Environment Variables
# Copy this file to .env and customize as needed

# RTL-TCP connection
RTL_SDR__RTL_TCP__HOST=192.168.31.34
RTL_SDR__RTL_TCP__PORT=1234

# Receiver settings
RTL_SDR__RECEIVER__FREQUENCY=915000000
RTL_SDR__RECEIVER__SAMPLE_RATE=2048000
RTL_SDR__RECEIVER__FFT_SIZE=2048

# Detector settings
RTL_SDR__DETECTOR__POWER_THRESHOLD=-70.0
RTL_SDR__DETECTOR__BANDWIDTH_THRESHOLD=100000
RTL_SDR__DETECTOR__Z_SCORE_THRESHOLD=1.5
RTL_SDR__DETECTOR__DETECTION_WINDOW=5
RTL_SDR__DETECTOR__MIN_DURATION=0.1
RTL_SDR__DETECTOR__TEST_MODE=false

# Display settings
RTL_SDR__DISPLAY__WATERFALL_LENGTH=50
RTL_SDR__DISPLAY__UPDATE_INTERVAL=50
